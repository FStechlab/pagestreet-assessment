generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
  importFileExtension = ""
}

datasource db {
  provider = "sqlite"
}


model Employee {
  id       String   @id @default(uuid())
  firstName String?
  lastName String?
  email String @unique
  role String?
  department String?
  createdAt DateTime @default(now())
  tasks Task[]
  assignedSubTasks SubTask[]
}

model Task {
  id String @id @default(uuid())
  title String
  description String @default("")
  employee Employee @relation(fields: [employeeId], references: [id])
  employeeId String
  status TaskStatus
  priority TaskPriority
  subTasks SubTask[]
  startDate DateTime
  dueDate DateTime
  createdAt DateTime @default(now())
}

model SubTask {
  id String @id @default(uuid())
  title String
  completed Boolean @default(false)
  task Task @relation(fields: [taskId], references: [id])
  taskId String
  assignee Employee? @relation(fields: [assigneeId], references: [id])
  assigneeId String?
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum TaskPriority {
  low
  medium
  high
}